rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function isServer() {
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/serverRoles/$(request.auth.uid));
    }

    match /site-images/{allPaths=**} {
      allow read: if true;
      allow write, delete: if isServer() || isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
